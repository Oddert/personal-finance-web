{
  "name": "personal-finance-web",
  "description": "Simple adaptable finance management system for personal use",
  "author": "Robyn Felicity Heather Veitch",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build:development": "cross-env NODE_ENV=\"development\" tsc -b && vite build",
    "build:staging": "cross-env NODE_ENV=\"staging\" tsc -b && vite build",
    "build:production": "cross-env NODE_ENV=\"production\" tsc -b && vite build",
    "build": "npm run build:production",
    "docs": "jsdoc -c jsdoc.conf.json -R README.md -r",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "postinstall": "husky install",
    "prepare": "husky",
    "preview": "vite preview",
    "start": "vite",
    "test": "echo \"Warning: no script 'test' defined\" && exit 0",
    "test:coverage": "echo \"Warning: no script 'test:coverage' defined\" && exit 0",
    "test:watch": "echo \"Warning: no script 'test:watch' defined\" && exit 0"
  },
