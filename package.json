    "i18next-http-backend": "^4.0.0",
    "json-2-csv": "^5.5.10",
    "jwt-decode": "^4.0.0",
    "locale-codes": "^1.3.1",
    "react": "^19.2.6",
    "react-apexcharts": "^2.1.0",
    "react-dom": "^19.2.6",
    "react-dropzone": "^15.0.0",
    "react-i18next": "^17.0.8",
    "react-redux": "^9.3.0",
